{
  "manifest_version": 3,
  "name": "Quick Screenshot",
  "version": "1.0",
  "description": "Cmd+Shift+S — capture the visible part of the page",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "take-screenshot": {
      "suggested_key": {
        "mac": "Command+Shift+S",
        "default": "Ctrl+Shift+S"
      },
      "description": "Capture the visible part of the page"
    }
  }
}
